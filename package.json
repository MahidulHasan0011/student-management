{
  "name": "student-management-system",
  "version": "1.0.0",
  "description": "Student Management System API",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:schema": "node database/db-init.js schema",  
    "db:migrate": "node database/db-init.js migrations",
    "db:views":   "node database/db-init.js views",
    "db:seed":   "node database/db-init.js seed",
    "db:init":   "node database/db-init.js all",
    "db:truncate": "node database/db-truncate.js",
    "db:fresh":   "node database/db-truncate.js && node database/db-init.js seed"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "nodemon": "^3.1.14",
    "pg": "^8.21.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "redis": "^4.6.14"
  },
   "devDependencies": {
    "nodemon": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
